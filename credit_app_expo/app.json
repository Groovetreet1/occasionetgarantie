{
  "expo": {
    "name": "MAD Crédits",
    "slug": "mad-credits",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "backgroundColor": "#0D1B2A"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCalendarsUsageDescription": "Permission pour programmer les rappels",
        "NSNotificationUsageDescription": "Notifications pour les rappels d'échéances"
      }
    },
    "android": {
      "package": "com.gomobile.madcredits",
      "adaptiveIcon": {
        "backgroundColor": "#0D1B2A"
      }
    },
    "plugins": [
      "expo-sqlite",
      "expo-asset",
      "expo-font",
      "@react-native-community/datetimepicker"
    ],
    "extra": {
      "eas": {
        "projectId": "b523cb79-2926-4675-8e16-f272ece93a09"
      }
    },
    "owner": "gomobile"
  }
}
